<launch>
  <!-- 配置文件 -->
  <arg name="config_file"
       default="$(find sunray_uav_control)/include/vision_pose/vision_pose_config.yaml"
       doc="vision_pose 配置文件路径" />

  <!-- 运行时参数 -->
  <arg name="publish_rate_hz" default="30.0" doc="向 PX4 发布频率(Hz)" />
  <arg name="odom_timeout_s" default="0.5" doc="外部里程计超时(s)" />
  <arg name="init_wait_timeout_s" default="5.0" doc="启动等待首帧超时(s)" />
  <arg name="local_odom_topic" default="/sunray/localization/local_odom" />
  <arg name="odom_status_topic" default="/sunray/localization/odom_status" />
  <arg name="mavros_ns" default="__AUTO__" doc="MAVROS namespace, e.g. /uav1/mavros; __AUTO__ uses uav_ns/uav_name+uav_id" />
  <arg name="auto_set_px4_params" default="false" doc="是否自动写入 PX4 参数" />
  <arg name="strict_param_check" default="true" doc="参数不匹配是否直接失败" />
  <arg name="allow_source_switch" default="true" doc="external_source 改变时是否允许切换配置" />

  <node pkg="sunray_uav_control"
        type="vision_pose_node"
        name="vision_pose"
        output="screen">
    <param name="publish_rate_hz" value="$(arg publish_rate_hz)" />
    <param name="odom_timeout_s" value="$(arg odom_timeout_s)" />
    <param name="init_wait_timeout_s" value="$(arg init_wait_timeout_s)" />
    <param name="local_odom_topic" value="$(arg local_odom_topic)" />
    <param name="odom_status_topic" value="$(arg odom_status_topic)" />
    <param name="mavros_ns" value="$(arg mavros_ns)" />
    <param name="auto_set_px4_params" value="$(arg auto_set_px4_params)" />
    <param name="strict_param_check" value="$(arg strict_param_check)" />
    <param name="allow_source_switch" value="$(arg allow_source_switch)" />

    <rosparam command="load" file="$(arg config_file)" />
  </node>
</launch>

