<launch>
  <arg name="config_yamlfile_path"
       default="$(find sunray_uav_control)/config/sunray_control_config.yaml" />
  <arg name="takeoff_land_cycles" default="1" />

  <node pkg="sunray_uav_control"
        type="origin_controller_takeoff_test"
        name="origin_controller_takeoff_test"
        output="screen">
    <param name="config_yamlfile_path" value="$(arg config_yamlfile_path)" />
    <param name="takeoff_land_cycles" value="$(arg takeoff_land_cycles)" />
  </node>
</launch>
